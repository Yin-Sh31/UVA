/* pages/payment/history.wxss */
.page {
  height: 100vh;
  background-color: #f5f5f5;
}

.container {
  padding-bottom: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 筛选和搜索区域 */
.filter-section {
  padding: 20rpx;
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.date-filter {
  margin-bottom: 20rpx;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
}

.date-picker image {
  width: 30rpx;
  height: 30rpx;
}

.search-box {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  height: 80rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-box input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
}

/* 交易记录列表 */
.transaction-list {
  max-height: calc(100vh - 400rpx);
}

.transaction-item {
  padding: 0 30rpx;
  background-color: #ffffff;
}

.transaction-info {
  padding: 30rpx 0;
}

.transaction-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.transaction-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.transaction-amount {
  font-size: 36rpx;
  font-weight: bold;
}

.transaction-amount.income {
  color: #e64340;
}

.transaction-amount.expense {
  color: #1aad19;
}

.transaction-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.transaction-time {
  font-size: 26rpx;
  color: #999999;
}

.transaction-type {
  font-size: 26rpx;
  color: #666666;
}

.transaction-divider {
  height: 1rpx;
  background-color: #f0f0f0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-state text {
  font-size: 28rpx;
  color: #999999;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
  color: #666666;
  font-size: 28rpx;
  background-color: #ffffff;
  margin-top: 20rpx;
}

.load-more:active {
  background-color: #f8f8f8;
}