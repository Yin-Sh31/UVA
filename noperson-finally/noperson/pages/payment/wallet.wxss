/* 钱包页面容器样式 */
.wallet-container {
  padding: 0 20rpx 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 钱包卡片样式 */
.wallet-card {
  margin: 30rpx 0;
  padding: 40rpx;
  background: linear-gradient(135deg, #4caf50 0%, #8bc34a 100%);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.2);
  position: relative;
  overflow: hidden;
}

.wallet-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.1;
  /* 移除背景图片，避免WXSS无法获取本地资源的问题 */
}

.wallet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.wallet-title {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.balance-section {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.balance-symbol {
  font-size: 48rpx;
  color: white;
  margin-right: 8rpx;
}

.balance-value,
.balance-amount {
  font-size: 72rpx;
  color: white;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.wallet-footer {
  text-align: center;
}

.wallet-tip {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 操作按钮区域 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.recharge-btn {
  background-color: #4caf50;
  color: white;
  font-size: 36rpx;
  font-weight: 500;
  border-radius: 10rpx;
  padding: 20rpx;
  line-height: 1.5;
}

.withdraw-btn {
  background-color: white;
  color: #333;
  font-size: 36rpx;
  font-weight: 500;
  border-radius: 10rpx;
  padding: 20rpx;
  line-height: 1.5;
  border: 1rpx solid #ddd;
}

/* 交易记录提示 */
.record-tip {
  margin-top: 40rpx;
  text-align: center;
  padding: 20rpx;
  background-color: white;
  border-radius: 10rpx;
}

.record-tip text {
  font-size: 28rpx;
  color: #999;
}

/* 模态框样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  z-index: 1001;
  padding-bottom: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-close image {
  width: 40rpx;
  height: 40rpx;
}

.modal-body {
  padding: 30rpx;
}

.current-balance {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.balance-label {
  font-size: 32rpx;
  color: #666;
}

.current-balance .balance-amount {
  font-size: 36rpx;
  font-weight: 600;
  color: #4caf50;
}

.input-section {
  margin: 30rpx 0;
}

.input-label {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.amount-input {
  display: flex;
  align-items: center;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
}

.input-symbol {
  font-size: 40rpx;
  color: #333;
  margin-right: 10rpx;
}

.amount-input input {
  flex: 1;
  font-size: 40rpx;
  color: #333;
  background-color: transparent;
}

.modal-footer {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 30rpx;
}

.modal-cancel-btn {
  background-color: #f5f5f5;
  color: #666;
  font-size: 36rpx;
  border-radius: 10rpx;
  padding: 20rpx;
  line-height: 1.5;
}

.modal-confirm-btn {
  background-color: #4caf50;
  color: white;
  font-size: 36rpx;
  border-radius: 10rpx;
  padding: 20rpx;
  line-height: 1.5;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

/* 响应式设计 */
@media (min-width: 768px) {
  .wallet-container {
    max-width: 600rpx;
    margin: 0 auto;
  }
  
  .modal-content {
    max-width: 600rpx;
    margin: 0 auto;
    bottom: auto;
    top: 50%;
    transform: translateY(-50%);
    border-radius: 20rpx;
  }
}