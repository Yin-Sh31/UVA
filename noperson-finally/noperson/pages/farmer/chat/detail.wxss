/* farmer/chat/detail.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.custom-nav-bar {
  height: 140rpx;
  background-color: #fff;
  display: flex;
  align-items: flex-end;
  padding: 0 30rpx 20rpx;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.nav-back:hover {
  background-color: #f5f5f5;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}

.nav-title {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
}

.name {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  text-align: center;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-type {
  font-size: 22rpx;
  color: #999;
  margin-left: 10rpx;
  padding: 4rpx 12rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  padding-top: 160rpx;
  overflow-y: auto;
}

.message-item {
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
}

.message-item.sent {
  align-items: flex-end;
}

.message-time {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 15rpx;
  padding: 4rpx 12rpx;
  background-color: rgba(0, 0, 0, 0.15);
  border-radius: 10rpx;
  align-self: center;
}

.message-item.received {
  justify-content: flex-start;
}

.message-content {
  display: flex;
  align-items: flex-start;
  max-width: 70%;
}

.message-item.sent .message-content {
  flex-direction: row;
}

.message-item.received .message-content {
  flex-direction: row;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #1AAD19;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.bubble {
  padding: 20rpx;
  border-radius: 12rpx;
  margin: 0 20rpx;
  position: relative;
  max-width: 100%;
}

.message-item.sent .bubble {
  background-color: #1AAD19;
}

.message-item.received .bubble {
  background-color: #fff;
}

.text {
  font-size: 30rpx;
  color: #333;
  word-break: break-word;
}

.message-item.sent .text {
  color: #fff;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.message-item.sent .time {
  color: rgba(255, 255, 255, 0.7);
}

.loading-tip {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 26rpx;
}

.input-area {
  height: 120rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.input {
  flex: 1;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
}

.send-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #e0e0e0;
  color: #999;
  font-size: 30rpx;
  border-radius: 40rpx;
  margin-left: 20rpx;
  padding: 0;
  transition: all 0.3s ease;
}

.send-btn.active {
  background-color: #1AAD19 !important;
  color: #fff !important;
  box-shadow: 0 2rpx 8rpx rgba(26, 173, 25, 0.3) !important;
}

.send-btn.active:active {
  opacity: 0.8;
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(26, 173, 25, 0.3) !important;
}

.send-btn[disabled] {
  background-color: #e0e0e0;
  color: #999;
  box-shadow: none;
}
