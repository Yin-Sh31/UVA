/* farmer/chat/list.wxss */
.container {
  height: 100vh;
  background: linear-gradient(180deg, #f8f8f8, #f5f5f5);
  display: flex;
  flex-direction: column;
}

/* 固定导航栏 */
navigation-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.conversation-list {
  flex: 1;
  height: calc(100vh - 88rpx - 120rpx); /* 减去导航栏高度和底部导航栏高度 */
  padding-top: calc(env(safe-area-inset-top) + 84px); /* 为 navigation-bar 预留空间，再增加20px让内容继续下移 */
  padding-bottom: 120rpx;
  overflow-y: auto;
}

.conversation-item {
  display: flex;
  padding: 36rpx 32rpx;
  background: linear-gradient(135deg, #fff, #fafafa);
  border-bottom: 1rpx solid rgba(238, 238, 238, 0.5);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.conversation-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(135deg, #1aad19, #16a085);
  opacity: 0;
  transition: all 0.3s ease;
}

.conversation-item:active::before {
  opacity: 1;
}

.conversation-item:active {
  background: linear-gradient(135deg, #f5f5f5, #f0f0f0);
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1aad19, #16a085);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(26, 173, 25, 0.2);
  overflow: hidden;
  position: relative;
}

.avatar-image {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  border-radius: 50%;
  background-color: transparent;
}

.avatar-text {
  color: #fff;
  font-size: 44rpx;
  font-weight: bold;
  z-index: 1;
}

.content {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 34rpx;
  color: #333;
  font-weight: 600;
}

.user-type {
  font-size: 24rpx;
  color: #1aad19;
  margin-left: 12rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(26, 173, 25, 0.1), rgba(22, 160, 133, 0.1));
  border-radius: 10rpx;
  font-weight: 500;
}

.time {
  font-size: 26rpx;
  color: #999;
  margin-left: auto;
  flex-shrink: 0;
}

.message {
  display: flex;
  align-items: center;
}

.last-message {
  font-size: 28rpx;
  color: #666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 40rpx;
}

.unread-badge {
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #ff4757, #ff6b81);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 71, 87, 0.3);
}

.unread-count {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.loading-tip {
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.no-more {
  padding: 40rpx;
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  background: linear-gradient(to right, transparent, rgba(0, 0, 0, 0.02), transparent);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #bbb;
  margin-top: 20rpx;
}

/* 自定义底部导航栏样式 */
.custom-tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #fff, #fafafa);
  border-top: 1rpx solid rgba(238, 238, 238, 0.5);
  margin-top: 40rpx;
  height: 100rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.03);
}

/* 固定底部定位样式 */
.custom-tab-bar.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  margin-top: 0;
  z-index: 999;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  transition: all 0.3s ease;
}

.tab-item:active {
  transform: scale(0.95);
}

.tab-item image {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 10rpx;
  opacity: 0.7;
  transition: all 0.3s ease;
}

.tab-item.active image {
  opacity: 1;
}

.tab-item text {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  font-weight: 500;
}

.tab-item.active text {
  color: #1aad19;
  font-weight: 600;
}
