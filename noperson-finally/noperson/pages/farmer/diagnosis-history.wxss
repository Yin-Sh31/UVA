.container {
  padding: 120rpx 20rpx 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-time {
  font-size: 28rpx;
  color: #666;
}

.crop-type {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  background-color: #f0f9ff;
  color: #1890ff;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.history-content {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.diagnosis-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.diagnosis-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.disease-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.confidence {
  font-size: 28rpx;
  font-weight: 500;
}

.low-confidence {
  color: #ff4d4f;
}

.pesticide, .measures {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.history-footer {
  display: flex;
  justify-content: flex-end;
}

.spray-btn {
  background-color: #1890ff;
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 12rpx 32rpx;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #666;
}
