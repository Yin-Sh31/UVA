<!-- farmer/user-info.wxml -->
<navigation-bar title="用户信息" background="#ffffff" color="#000000" back="true"></navigation-bar>
<view class="user-info-container">
  <!-- 头像区域 -->
  <view class="avatar-section">
    <view class="avatar-container" bindtap="chooseAvatar" wx:if="{{editable}}">
      <image 
        class="user-avatar" 
        src="{{formData.avatar || '/assets/images/user-avatar.png'}}"
        mode="aspectFill"
      ></image>
      <view class="avatar-edit-overlay">
        <text class="avatar-edit-icon">📷</text>
      </view>
    </view>
    <view class="avatar-container" wx:else>
      <image 
        class="user-avatar" 
        src="{{userInfo.avatar || '/assets/images/user-avatar.png'}}"
        mode="aspectFill"
      ></image>
    </view>
  </view>
  
  <!-- 信息表单 -->
  <view class="form-section">
    <!-- 真实姓名 -->
    <view class="form-item">
      <view class="form-label">真实姓名</view>
      <view class="form-content">
        <input 
          class="form-input {{formErrors.realName ? 'input-error' : ''}}" 
          value="{{formData.realName}}" 
          bindinput="onInputChange" 
          data-field="realName" 
          placeholder="请输入真实姓名"
          disabled="{{!editable}}"
        />
      </view>
    </view>
    <!-- 错误提示 -->
    <view class="error-message" wx:if="{{editable && formErrors.realName}}">{{formErrors.realName}}</view>
    
    <!-- 用户名 -->
    <view class="form-item">
      <view class="form-label">用户名</view>
      <view class="form-content">
        <text class="form-text">{{userInfo.username || '未设置'}}</text>
      </view>
    </view>
    
    <!-- 手机号 -->
    <view class="form-item">
      <view class="form-label">手机号</view>
      <view class="form-content">
        <text class="form-text">{{userInfo.phone || '未设置'}}</text>
      </view>
    </view>
    
    <!-- 详细地址 -->
    <view class="form-item">
      <view class="form-label">详细地址</view>
      <view class="form-content">
        <view 
          wx:if="{{editable}}"
          class="address-input-wrapper"
        >
          <input 
            class="form-input address-input"
            value="{{formData.address}}" 
            bindinput="onInputChange"
            data-field="address"
            placeholder="请输入或获取地址"
          />
          <button 
            class="get-location-btn"
            bindtap="getCurrentLocation"
            type="primary"
            size="mini"
          >
            获取位置
          </button>
        </view>
        <text wx:else class="form-text">{{userInfo.address || '未设置'}}</text>
      </view>
    </view>

    <!-- 角色类型 -->
    <view class="form-item">
      <view class="form-label">角色类型</view>
      <view class="form-content">
        <text class="form-text">
          {{userInfo.roleType === 1 ? '农户' : userInfo.roleType === 2 ? '飞手' : userInfo.roleType === 3 ? '机主' : '未设置'}}
        </text>
      </view>
    </view>
    
    <!-- 创建时间 -->
    <view class="form-item">
      <view class="form-label">创建时间</view>
      <view class="form-content">
        <text class="form-text">{{userInfo.createTime || '未设置'}}</text>
      </view>
    </view>
    
    <!-- 最后登录时间 -->
    <view class="form-item">
      <view class="form-label">最后登录</view>
      <view class="form-content">
        <text class="form-text">{{userInfo.lastLoginTime || '未设置'}}</text>
      </view>
    </view>
  </view>
  
  <!-- 状态显示 -->
  <view class="status-display">
    <text class="status-text">当前状态: {{editable ? '编辑模式' : '查看模式'}}</text>
  </view>
  
  <!-- 操作按钮 -->
  <view class="action-buttons">
    
    <!-- 编辑/保存/取消按钮 -->
    <button 
      class="primary-button" 
      catchtap="saveUserInfo" 
      wx:if="{{editable}}"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      保存
    </button>
    <button 
      class="primary-button" 
      catchtap="toggleEdit" 
      wx:else
      disabled="{{loading}}"
    >
      编辑
    </button>
    <button 
      class="cancel-button" 
      catchtap="toggleEdit" 
      wx:if="{{editable}}"
      disabled="{{loading}}"
    >
      取消
    </button>
  </view>
</view>

