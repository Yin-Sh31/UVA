.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 缓存数据提示 */
.cache-tip {
  background-color: #fff3cd;
  color: #856404;
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #ffeaa7;
}

.cache-label {
  background-color: #856404;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

/* 飞手列表 */
.flyer-list {
  flex: 1;
  padding: 20rpx;
  height: calc(100vh - 180rpx);
  overflow: hidden;
}

/* 飞手项 */
.flyer-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  transition: transform 0.2s, box-shadow 0.2s;
}

.flyer-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 5rpx rgba(0, 0, 0, 0.05);
}

.flyer-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.flyer-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f0f0f0;
  margin-right: 30rpx;
  position: relative;
}

/* 状态标识 */
.status-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #fff;
}

.status-free {
  background-color: #28a745;
}

.status-busy {
  background-color: #dc3545;
}

.flyer-avatar image {
  width: 100%;
  height: 100%;
}

.flyer-details {
  flex: 1;
}

.flyer-name-rating {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.flyer-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.rating {
  display: flex;
  align-items: center;
  flex-direction: column;
  align-items: flex-end;
}

.rating-value {
  font-size: 28rpx;
  color: #ff6700;
  font-weight: bold;
}

.star-container {
  display: flex;
  margin-top: 4rpx;
}

.star {
  font-size: 24rpx;
  color: #ff6700;
  margin-right: 2rpx;
}

.star.empty {
  color: #ddd;
}

.flyer-intro {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.flyer-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.flyer-orders,
.flyer-evaluation,
.flyer-positive {
  font-size: 26rpx;
  color: #999;
}

.flyer-positive {
  color: #28a745;
}

/* 标签样式 */
.flyer-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  background-color: #f0f2f5;
  color: #666;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

/* 操作按钮 */
.flyer-actions {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-btn {
  font-size: 26rpx;
  line-height: 70rpx;
  padding: 0 24rpx;
  background-color: #576b95;
  color: white;
  border-radius: 8rpx;
  margin: 0;
}

.contact-btn::after {
  border: none;
}

.contact-btn:active {
  opacity: 0.8;
}

.invite-btn {
  font-size: 28rpx;
  line-height: 80rpx;
  padding: 0 30rpx;
  transition: opacity 0.2s;
  margin: 0;
}

.invite-btn::after {
  border: none;
}

.invite-btn:active {
  opacity: 0.8;
}

.invite-btn.disabled {
  background-color: #d9d9d9;
  color: #666;
}

/* 加载状态 */
.loading-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

/* 加载动画 */
.loading-spinner {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #3498db;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  color: #999;
  font-size: 32rpx;
}

.empty-subtext {
  color: #bbb;
  font-size: 28rpx;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 错误状态 */
.error-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  gap: 30rpx;
}

.error-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
}

.error-text {
  color: #999;
  font-size: 32rpx;
  text-align: center;
}

.retry-btn {
  margin-top: 20rpx;
  min-width: 200rpx;
}

/* 响应式适配 */
@media screen and (max-width: 375px) {
  .flyer-list {
    padding: 10rpx;
    height: calc(100vh - 160rpx);
  }
  
  .flyer-item {
    padding: 20rpx;
    margin-bottom: 15rpx;
  }
  
  .flyer-avatar {
    width: 100rpx;
    height: 100rpx;
    margin-right: 20rpx;
  }
  
  .flyer-name {
    font-size: 32rpx;
  }
  
  .flyer-intro {
    font-size: 26rpx;
  }
}