/* publish-spray-demand.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.publish-demand-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.form-scroll {
  height: calc(100vh - 44px);
  overflow-y: auto;
}

.form-container {
  padding: 40rpx;
  background-color: #fff;
}

.input-group {
  margin-bottom: 36rpx;
  position: relative;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #333;
  transition: all 0.3s;
}

.textarea {
  width: 100%;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #333;
  min-height: 160rpx;
  transition: all 0.3s;
}

/* 错误状态 */
.input-error {
  border-color: #ff4d4f !important;
}

/* 聚焦状态 */
.input-focus {
  border-color: #1890ff;
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.1);
}

/* 字数统计 */
.char-count {
  position: absolute;
  right: 0;
  bottom: -24rpx;
  font-size: 22rpx;
  color: #999;
}

/* 错误提示 */
.error-message {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
  line-height: 1.4;
}

.map-btn {
  width: 100%;
  height: 80rpx;
  margin-top: 16rpx;
  background-color: #fff;
  color: #1890ff;
  font-size: 28rpx;
  line-height: 80rpx;
  border: 2rpx solid #1890ff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.map-btn:active {
  background-color: #f0f9ff;
}

.picker {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.3s;
}

.picker:active {
  background-color: #f5f5f5;
}

.picker-text {
  font-size: 30rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.picker-arrow {
  width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-arrow image {
  width: 20rpx;
  height: 20rpx;
}

/* 地址输入器相关样式 */
.address-input-wrapper {
  display: flex;
  align-items: center;
  width: 100%;
  position: relative;
}

.address-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  padding-right: 20rpx;
}

/* 获取位置按钮样式 */
.get-location-btn {
  min-width: 140rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
  margin-left: 20rpx;
}

/* 自动估算按钮 */
.budget-calc-btn {
  margin-top: 16rpx;
  border: 2rpx solid #722ed1;
  color: #722ed1;
  background-color: #fff;
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.budget-calc-btn:active {
  background-color: #f9f0ff;
}

.button-group {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.reset-btn {
  flex: 1;
  height: 96rpx;
  background-color: #fff;
  color: #666;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: 2rpx solid #d9d9d9;
  line-height: 96rpx;
}

.reset-btn:active {
  background-color: #f5f5f5;
}

.submit-btn {
  flex: 2;
  height: 96rpx;
  border-radius: 12rpx;
  background-color: #e0e0e0;
  color: #999;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 96rpx;
}

.submit-btn-active {
  background-color: #52c41a;
  color: #fff;
}

.submit-btn-active:active {
  opacity: 0.8;
}

.submit-btn[disabled] {
  background-color: #d9d9d9;
  color: #fff;
}

/* 加载状态 */
.loading {
  pointer-events: none;
}

/* 适配不同尺寸屏幕 */
@media screen and (min-width: 768px) {
  .form-container {
    max-width: 600rpx;
    margin: 0 auto;
    border-radius: 20rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  }
}