/* view-report.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.view-report-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.report-scroll {
  flex: 1;
  overflow-y: auto;
  height: calc(100vh - 200rpx);
  -webkit-overflow-scrolling: touch;
}

/* 缓存数据提示 */
.cached-data-hint {
  background-color: #fff9e6;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #ffe082;
}

.hint-text {
  font-size: 26rpx;
  color: #ff9800;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
}

.error-text {
  font-size: 28rpx;
  color: #e64340;
  margin-bottom: 30rpx;
  text-align: center;
}

.retry-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background-color: #1aad19;
  color: #fff;
  border-radius: 40rpx;
}

.report-header {
  padding: 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.search-group {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #333;
  transition: all 0.3s;
}

.search-input:focus {
  border-color: #1aad19;
  box-shadow: 0 0 0 2rpx rgba(26, 173, 25, 0.2);
}

.search-input:disabled {
  background-color: #f5f5f5;
  color: #999;
}

.search-btn {
  width: 180rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  background-color: #1aad19;
  color: #fff;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.search-btn:active {
  opacity: 0.8;
}

.search-btn:disabled {
  background-color: #e0e0e0;
  color: #999;
}

.report-content {
  padding: 30rpx;
  background-color: #fff;
}

/* 更新时间提示 */
.update-time {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.report-section {
  margin-bottom: 30rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background-color: #f8f8f8;
  transition: all 0.3s;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -1rpx;
  width: 60rpx;
  height: 4rpx;
  background-color: #1aad19;
}

.info-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
  padding: 10rpx 0;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-word;
}

.multi-line {
  white-space: pre-wrap;
  line-height: 1.8;
  padding: 10rpx 0;
}

.status-0 {
  color: #999;
}

.status-1 {
  color: #ff9500;
}

.status-2 {
  color: #1aad19;
}

.status-3 {
  color: #e64340;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 220rpx;
  height: 220rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  transition: all 0.3s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.image-item-hover {
  transform: scale(1.05);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.preview-image {
  width: 100%;
  height: 100%;
  transition: all 0.3s;
}

.image-count {
  position: absolute;
  bottom: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx 0 12rpx 0;
}

.action-buttons {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 30rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.btn-hover {
  transform: scale(0.98);
}

.action-btn:disabled {
  opacity: 0.6;
}

/* 加载中状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(26, 173, 25, 0.2);
  border-top-color: #1aad19;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

.no-report {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
  text-align: center;
}

.no-report image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.7;
}

.no-report-title {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.no-report-subtitle {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
}

/* 响应式设计 */
@media screen and (max-width: 375px) {
  .image-item {
    width: 160rpx;
    height: 160rpx;
  }
  
  .info-label {
    width: 160rpx;
    font-size: 26rpx;
  }
  
  .info-value {
    font-size: 26rpx;
  }
  
  .search-btn {
    width: 150rpx;
  }
}