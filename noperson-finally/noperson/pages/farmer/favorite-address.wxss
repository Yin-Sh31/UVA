/* favorite-address.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.content {
  padding: 32rpx;
}

.address-section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.address-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.address-info {
  margin-bottom: 32rpx;
}

.info-item {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.label {
  width: 160rpx;
  color: #666666;
}

.value {
  flex: 1;
  color: #333333;
  word-break: break-all;
}

.delete-btn {
  width: 100%;
  height: 72rpx;
  background-color: #ff4d4f;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.empty-state {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 64rpx;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999999;
}
