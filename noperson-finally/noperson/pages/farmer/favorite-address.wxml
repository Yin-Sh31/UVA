<!--favorite-address.wxml--><navigation-bar title="常用地址管理" background="#ffffff" color="#000000" back="true"></navigation-bar><view class="container"><view class="content" wx:if="{{!loading}}"><!-- 喷洒需求地址 --><view class="address-section"><view class="section-title"><text>喷洒需求地址</text></view><view wx:if="{{sprayAddress}}" class="address-card"><view class="address-info"><view class="info-item"><text class="label">地块名称：</text><text class="value">{{sprayAddress.landName}}</text></view><view class="info-item"><text class="label">地块位置：</text><text class="value">{{sprayAddress.landLocation}}</text></view><view class="info-item"><text class="label">地块面积：</text><text class="value">{{sprayAddress.landArea}}亩</text></view><view class="info-item"><text class="label">作物类型：</text><text class="value">{{sprayAddress.cropType}}</text></view><view class="info-item"><text class="label">病虫害类型：</text><text class="value">{{sprayAddress.pestType || '无'}}</text></view></view><button class="delete-btn" data-type="1" bindtap="deleteAddress">删除</button></view><view wx:else class="empty-state"><text>暂无喷洒需求常用地址</text></view></view><!-- 巡检需求地址 --><view class="address-section"><view class="section-title"><text>巡检需求地址</text></view><view wx:if="{{inspectionAddress}}" class="address-card"><view class="address-info"><view class="info-item"><text class="label">地块名称：</text><text class="value">{{inspectionAddress.landName}}</text></view><view class="info-item"><text class="label">地块位置：</text><text class="value">{{inspectionAddress.landLocation}}</text></view><view class="info-item"><text class="label">地块面积：</text><text class="value">{{inspectionAddress.landArea}}亩</text></view><view class="info-item"><text class="label">作物类型：</text><text class="value">{{inspectionAddress.cropType}}</text></view><view class="info-item"><text class="label">巡检目的：</text><text class="value">{{inspectionAddress.inspectionPurpose || '无'}}</text></view><view class="info-item"><text class="label">期望分辨率：</text><text class="value">{{inspectionAddress.expectedResolution || '无'}}</text></view></view><button class="delete-btn" data-type="2" bindtap="deleteAddress">删除</button></view><view wx:else class="empty-state"><text>暂无巡检需求常用地址</text></view></view></view><view wx:else class="loading"><text>加载中...</text></view></view>