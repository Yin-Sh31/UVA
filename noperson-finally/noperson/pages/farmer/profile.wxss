.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f7f7f7;
  box-sizing: border-box;
  padding: 0;
  margin: 0;
  width: 100%;
}

/* 内容容器 */
.content-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  width: 100%;
  padding-bottom: 140rpx;
}

/* 用户信息卡片 */
.user-card {
  background-color: #fff;
  padding: 40rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
  border-radius: 20rpx;
  transition: all 0.3s;
}

.avatar-container {
  margin-right: 30rpx;
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  border: 2rpx solid #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s;
}

.avatar:active {
  transform: scale(1.05);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 28rpx;
  color: #999;
}

/* 余额显示样式 */
.balance-container {
  display: flex;
  align-items: baseline;
  margin-top: 10rpx;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #07c160 0%, #05b056 100%);
  border-radius: 20rpx;
  width: fit-content;
  box-shadow: 0 3rpx 10rpx rgba(7, 193, 96, 0.2);
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-right: 10rpx;
}

.balance-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.edit-btn {
  color: #07c160;
  font-size: 30rpx;
  padding: 10rpx 20rpx;
  border-radius: 15rpx;
  transition: all 0.3s;
}

.edit-btn:active {
  background-color: #f0f0f0;
  transform: translateY(2rpx);
}

/* 功能菜单 */
.menu-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1px solid #eee;
  transition: all 0.3s;
}

.menu-item:active {
  background-color: #f8f8f8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 30rpx;
}

.menu-icon image {
  width: 100%;
  height: 100%;
}

.menu-name {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.menu-arrow {
  width: 20rpx;
  height: 32rpx;
}

.menu-arrow image {
  width: 100%;
  height: 100%;
  opacity: 0.5;
}

/* 退出登录按钮 */
.logout-section {
  padding: 40rpx;
  margin-top: auto;
}

.logout-btn {
  font-size: 32rpx;
  background-color: #fff;
  border: none;
  color: #e64340;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 60rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.logout-btn:active {
  background-color: #f8f8f8;
  box-shadow: 0 1rpx 5rpx rgba(0, 0, 0, 0.05);
  transform: translateY(2rpx);
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

/* 隐藏原生按钮的边框 */
button::after {
  border: none;
}

/* 分隔线 */
.divider {
  height: 10rpx;
  background-color: #f7f7f7;
}

/* 自定义底部导航栏样式 */
.custom-tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 0;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  margin-top: 40rpx;
  height: 100rpx;
}

/* 固定底部定位样式 */
.custom-tab-bar.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  margin-top: 0;
  z-index: 999;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.tab-item image {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 10rpx;
  opacity: 0.7;
  transition: all 0.3s ease;
}

.tab-item.active image {
  opacity: 1;
}

.tab-item text {
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

.tab-item.active text {
  color: #1AAD19;
}
