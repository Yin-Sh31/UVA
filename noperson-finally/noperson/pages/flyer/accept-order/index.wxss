/* flyer/accept-order/index.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.accept-order-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* 订单类型选择器 */
.order-type-selector {
  display: flex;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.type-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  font-size: 32rpx;
  color: #666;
  position: relative;
}

.type-item.active {
  color: #1aad19;
}

.type-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background-color: #1aad19;
  border-radius: 3rpx;
}



/* 订单列表区域 */
.orders-scroll {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
}

.orders-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.order-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.order-time {
  font-size: 26rpx;
  color: #999;
}

.order-info {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 180rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}



.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #e64340;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.contact-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background-color: #576b95;
  color: #fff;
  border-radius: 12rpx;
  margin: 0;
  padding: 0;
}

.contact-btn::after {
  border: none;
}

.accept-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background-color: #1aad19;
  color: #fff;
  border-radius: 12rpx;
  margin: 0;
  padding: 0;
}

.accept-btn::after {
  border: none;
}

/* 加载状态 */
.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
}

.loading-more text {
  font-size: 28rpx;
  color: #999;
}

.no-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
}

.no-more text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
}