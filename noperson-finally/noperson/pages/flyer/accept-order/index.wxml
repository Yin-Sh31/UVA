<!-- flyer/accept-order/index.wxml -->
<view class="accept-order-container">
  <navigation-bar title="接单管理" back="false" color="black" background="#FFF"></navigation-bar>
  
  <!-- 订单类型选择器 -->
  <view class="order-type-selector">
    <view 
      class="type-item {{orderType === 'all' ? 'active' : ''}}"
      data-type="all"
      bindtap="switchOrderType"
    >
      <text>全部需求</text>
    </view>
    <view 
      class="type-item {{orderType === 'inspection' ? 'active' : ''}}"
      data-type="inspection"
      bindtap="switchOrderType"
    >
      <text>巡检需求</text>
    </view>
    <view 
      class="type-item {{orderType === 'spray' ? 'active' : ''}}"
      data-type="spray"
      bindtap="switchOrderType"
    >
      <text>喷洒需求</text>
    </view>
  </view>
  

  
  <!-- 订单列表 -->
  <view class="orders-scroll">
    <view class="orders-list">
      <view 
        wx:for="{{waitingOrders}}" 
        wx:key="demandId"
        class="order-item"
        bindtap="viewOrderDetail"
        data-demand-id="{{item.demandId || item.id}}"
      >
        <view class="order-header">
          <text class="order-title">{{item.landName || '订单'}}</text>
          <text class="order-time">{{item.createTime || '--'}}</text>
        </view>
        
        <view class="order-info">
          <view class="info-row">
            <text class="info-label">订单编号：</text>
            <text class="info-value">{{item.demandId || item.id}}</text>
          </view>
          
          <view class="info-row">
            <text class="info-label">任务类型：</text>
            <text class="info-value">{{item.orderType === 2 || item.demandType === 'inspection' || item.type === 2 || item.type === 'inspection' ? '农业巡检' : '喷洒作业'}}</text>
          </view>
          
          <view class="info-row">
            <text class="info-label">地块位置：</text>
            <text class="info-value">{{item.landLocation || '未填写'}}</text>
          </view>
          

          
          <view class="info-row">
            <text class="info-label">面积：</text>
            <text class="info-value">{{item.landArea || 0}} 亩</text>
          </view>
          
          <view class="info-row">
            <text class="info-label">期望时间：</text>
            <text class="info-value">{{item.expectedTime || '--'}}</text>
          </view>
        </view>
        
        <view class="order-footer">
          <text class="order-price">¥{{item.budget || 0}}</text>
          <view class="action-buttons">
            <button 
              class="accept-btn"
              data-demand-id="{{item.id || item.demandId}}"
              catchtap="acceptOrder"
            >
              立即接单
            </button>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    
    <!-- 没有更多数据 -->
    <view class="no-more" wx:if="{{!hasMore && waitingOrders.length > 0}}">
      <text>没有更多数据了</text>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && waitingOrders.length === 0}}">
      <image src="/assets/images/user-info.png" mode="aspectFit"></image>
      <text class="empty-text">暂无待接单</text>
    </view>
  </view>
</view>