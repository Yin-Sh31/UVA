/* 飞手当前租借设备页面样式 */
.container {
  height: 100vh;
  background-color: #f5f5f5;
}

.content-container {
  height: calc(100vh - 60px);
}

.loading-state, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  color: #999;
}

.loading-spinner {
  width: 50rpx;
  height: 50rpx;
  border: 3rpx solid #f3f3f3;
  border-top: 3rpx solid #007AFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.device-list {
  padding: 20rpx;
}

.device-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
}

.device-image-container {
  width: 120rpx;
  height: 120rpx;
  margin-right: 20rpx;
}

.device-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  object-fit: cover;
}

.device-info {
  flex: 1;
}

.device-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.device-type {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.rental-info {
  display: flex;
  align-items: center;
}

.rental-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.rental-time {
  font-size: 24rpx;
  color: #333;
}

.action-buttons {
  margin-left: 20rpx;
}

.release-btn {
  width: 160rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  background-color: #FF3B30;
  color: #fff;
  border-radius: 30rpx;
  border: none;
  padding: 0;
}

.release-btn:active {
  background-color: #E63946;
}