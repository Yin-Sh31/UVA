/* flyer/all-farmers/farmer-detail.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  position: relative;
}

/* 可滚动内容区域 */
.scrollable-content {
  height: calc(100vh - 140rpx);
  overflow-y: auto;
  padding-bottom: 30rpx;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
}

/* 用户信息不显示时的样式 */
.no-info {
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
  background-color: #f9f9f9;
  margin: 20rpx;
  border-radius: 10rpx;
}

/* 需求列表部分 */
.demands-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.demands-list {
  width: 100%;
}

.demand-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.demand-item:last-child {
  border-bottom: none;
}

.demand-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.demand-type {
  display: flex;
  align-items: center;
}

.type-tag {
  font-size: 24rpx;
  color: #fff;
  background-color: #1890ff;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.demand-id {
  font-size: 24rpx;
  color: #999;
}

.demand-status {
  font-size: 24rpx;
}

.status-text {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.status-waiting {
  color: #fa8c16;
  background-color: #fff7e6;
}

.status-processing {
  color: #1890ff;
  background-color: #e6f7ff;
}

.status-completed {
  color: #52c41a;
  background-color: #f6ffed;
}

.status-cancelled {
  color: #999;
  background-color: #f5f5f5;
}

.demand-info {
  width: 100%;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  color: #999;
  width: 120rpx;
}

.info-value {
  color: #333;
  flex: 1;
  word-break: break-all;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999;
}

.load-more-text {
  color: #1890ff;
}

.no-more {
  color: #999;
}

/* 加载中状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 600rpx;
  color: #999;
  font-size: 28rpx;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 600rpx;
}

.error-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.retry-button {
  font-size: 28rpx;
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  background-color: #07c160;
  color: #fff;
}

/* 详情内容样式 */
.detail-content {
  background-color: #fff;
  margin-top: 20rpx;
}

/* 头像和基本信息部分 */
.profile-section {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.avatar-container {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f0f0f0;
  margin-right: 30rpx;
}

.avatar {
  width: 100%;
  height: 100%;
}

.basic-info {
  flex: 1;
}

.real-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.status-tag {
  font-size: 24rpx;
  color: #52c41a;
  background-color: #f6ffed;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
  margin-left: 10rpx;
}

.status-tag.disabled {
  color: #999;
  background-color: #f5f5f5;
}

/* 详细信息列表 */
.info-section {
  padding: 0 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.info-value.balance {
  color: #ff6b6b;
  font-size: 32rpx;
  font-weight: bold;
}

/* 手机号操作按钮 */
.phone-actions {
  display: flex;
  align-items: center;
}

.action-buttons {
  display: flex;
  margin-left: 20rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  margin-left: 10rpx;
  background-color: #f0f0f0;
  color: #666;
  border-radius: 20rpx;
}

.action-btn:nth-child(1) {
  background-color: #e6f7ff;
  color: #1890ff;
}

.action-btn:nth-child(2) {
  background-color: #f6ffed;
  color: #52c41a;
}

/* 底部操作按钮 */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  z-index: 100;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
}

.chat-button {
  width: 100%;
  background-color: #07c160;
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx 0;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.chat-button:active {
  opacity: 0.8;
}

.chat-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}