/* flyer/all-farmers/index.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  position: relative;
}

/* 可滚动内容区域 */
.scrollable-content {
  height: calc(100vh - 0rpx);
  overflow-y: auto;
  padding-bottom: 20rpx;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
}

/* 搜索栏样式 */
.search-bar {
  padding: 20rpx;
  background-color: #fff;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background-color: transparent;
}

/* 列表样式 */
.farmers-list {
  margin-top: 20rpx;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载状态样式 */
.loading-state {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 农户列表项样式 */
.farmer-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  background-color: #fff;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.farmer-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f0f0f0;
  margin-right: 24rpx;
}

.farmer-avatar image {
  width: 100%;
  height: 100%;
}

.farmer-info {
  flex: 1;
  min-width: 0;
}

.farmer-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.farmer-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.farmer-phone {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 0;
}

.farmer-balance {
  font-size: 28rpx;
  color: #ff6b6b;
  margin-bottom: 8rpx;
}

.farmer-join-time {
  font-size: 24rpx;
  color: #999;
}

.arrow-icon {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 16rpx;
}

/* 加载更多提示 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}