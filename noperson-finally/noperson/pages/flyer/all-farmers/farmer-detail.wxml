<!-- flyer/all-farmers/farmer-detail.wxml -->
<view class="container">
  <!-- 自定义导航栏 -->
  <navigation-bar back="true" title="农户详情"></navigation-bar>
  
  <!-- 可滚动内容区域 -->
  <view class="scrollable-content">
    <!-- 加载中状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    
    <!-- 非加载状态 -->
    <view wx:else>
      <!-- 错误状态 -->
      <view class="error-state" wx:if="{{error}}">
        <image src="/assets/images/no-message.svg" class="error-image" mode="aspectFit" />
        <text class="error-text">获取农户信息失败</text>
        <button class="retry-button" bindtap="refreshFarmerInfo">重试</button>
      </view>
      
      <!-- 农户详情内容 -->
      <view class="detail-content" wx:else>
        <!-- 头像和基本信息 -->
        <view class="profile-section">
          <view class="avatar-container">
            <image src="{{farmerInfo && farmerInfo.avatar ? farmerInfo.avatar : '/assets/images/user-avatar.png'}}" class="avatar" mode="aspectFill" />
          </view>
        </view>
        
        <!-- 详细信息列表 -->
        <view class="info-section">
          <view class="info-item">
            <text class="info-label">用户名</text>
            <text class="info-value">{{farmerInfo ? (farmerInfo.username || '-') : '-'}}</text>
          </view>
          
          <view class="info-item">
            <text class="info-label">手机号</text>
            <view class="phone-actions">
              <text class="info-value">{{farmerInfo && farmerInfo.phone ? farmerInfo.phone : '未设置'}}</text>
              <view class="action-buttons">
                <button class="action-btn" size="mini" bindtap="makePhoneCall" data-phone="{{farmerInfo && farmerInfo.phone ? farmerInfo.phone : ''}}" wx:if="{{farmerInfo && farmerInfo.phone}}">
                  拨打
                </button>
                <button class="action-btn" size="mini" bindtap="copyPhoneNumber" data-phone="{{farmerInfo && farmerInfo.phone ? farmerInfo.phone : ''}}" wx:if="{{farmerInfo && farmerInfo.phone}}">
                  复制
                </button>
              </view>
            </view>
          </view>
          
          <view class="info-item">
            <text class="info-label">真实姓名</text>
            <text class="info-value">{{farmerInfo ? (farmerInfo.realName || '-') : '-'}}</text>
          </view>
        </view>
        
        <!-- 农户需求列表 -->
        <view class="demands-section">
          <view class="section-title">
            <text>农户需求列表</text>
          </view>
          
          <!-- 需求列表 -->
          <view class="demands-list">
            <!-- 需求项 -->
            <block wx:if="{{demandList && demandList.length > 0}}">
              <view class="demand-item" wx:for="{{demandList}}" wx:key="id" bindtap="viewDemandDetail" data-demand-id="{{item.id || item.demandId}}">
                <view class="demand-header">
                  <view class="demand-type">
                    <text class="type-tag">{{item.orderType === 1 ? '喷洒' : '巡检'}}</text>
                    <text class="demand-id">需求ID: {{item.id || item.demandId || '-'}}</text>
                  </view>
                  <view class="demand-status">
                    <text class="status-text {{item.status === 0 ? 'status-waiting' : item.status === 1 ? 'status-processing' : item.status === 2 ? 'status-completed' : 'status-cancelled'}}">{{item.statusDesc || (item.status === 0 ? '待接单' : item.status === 1 ? '进行中' : item.status === 2 ? '已完成' : item.status === 3 ? '已取消' : '未知状态')}}</text>
                  </view>
                </view>
                
                <view class="demand-info">
                  <view class="info-row">
                    <text class="info-label">位置:</text>
                    <text class="info-value">{{item.landLocation || item.location || '-'}}</text>
                  </view>
                  <view class="info-row">
                    <text class="info-label">面积:</text>
                    <text class="info-value">{{item.landArea || item.area || '0'}} 亩</text>
                  </view>
                  <view class="info-row" wx:if="{{item.expectedTime}}">
                    <text class="info-label">期望时间:</text>
                    <text class="info-value">{{item.expectedTime}}</text>
                  </view>
                  <view class="info-row" wx:if="{{item.createTime || item.time}}">
                    <text class="info-label">发布时间:</text>
                    <text class="info-value">{{item.createTime || item.time}}</text>
                  </view>
                </view>
              </view>
            </block>
            
            <!-- 空状态 -->
            <view class="empty-state" wx:else>
              <text>{{loadingDemands ? '加载中...' : '暂无需求信息'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 底部操作按钮 - 固定在底部 -->
  <view class="bottom-actions">
    <button class="chat-button" bindtap="startChatWithFarmer">
      <text class="chat-icon">💬</text>
      发起聊天
    </button>
  </view>
</view>