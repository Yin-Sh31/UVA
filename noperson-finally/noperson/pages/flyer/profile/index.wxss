page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 内容容器 */
.content-container {
  flex: 1;
  width: 100%;
}

/* 用户信息卡片 */
.user-card {
  background-color: #ffffff;
  padding: 30rpx;
  display: flex;
  align-items: center;
  border-bottom: 1px solid #eee;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.avatar-container {
  margin-right: 30rpx;
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.user-details {
  display: flex;
  gap: 20rpx;
  margin-bottom: 15rpx;
}

.audit-status {
  font-size: 24rpx;
  color: #1aad19;
  background-color: #f0f9f0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.skill-level {
  font-size: 24rpx;
  color: #666;
}

/* 信用评分样式 */
.credit-info {
  margin-bottom: 15rpx;
}

.rating-container {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 10rpx;
}

.score-value {
  font-size: 28rpx;
  color: #faad14;
  font-weight: bold;
}

.star-container {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 24rpx;
  color: #faad14;
}

.star.empty {
  color: #d9d9d9;
}

.credit-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #666;
}

/* 余额显示样式 */
.balance-container {
  display: flex;
  align-items: baseline;
  margin-top: 10rpx;
  padding: 10rpx 20rpx;
  background-color: #f0f9f0;
  border-radius: 20rpx;
  width: fit-content;
}

.balance-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
}

.balance-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #1aad19;
}

.edit-btn {
  color: #1aad19;
  font-size: 30rpx;
}

/* 功能菜单 */
.menu-list {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 0 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1px solid #eee;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 30rpx;
}

.menu-icon image {
  width: 100%;
  height: 100%;
}

.menu-name {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.arrow-icon {
  font-size: 36rpx;
  color: #999;
  opacity: 0.7;
}

.menu-item.active {
  background-color: #f5f5f5;
}

.menu-item:active {
  background-color: #f5f5f5;
}

/* 退出登录按钮 */
.logout-section {
  padding: 40rpx;
  margin-top: auto;
}

.logout-btn {
  font-size: 32rpx;
  background-color: #fff;
  border: 1px solid #eee;
  color: #e64340;
}