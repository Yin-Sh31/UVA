<!-- flyer/owner-info/index.wxml -->
<view class="owner-info-container">
  <navigation-bar title="机主信息" back="true" color="black" background="#FFF"></navigation-bar>
  
  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
  
  <!-- 错误状态 -->
  <view class="error-container" wx:if="{{error && !loading}}">
    <image src="/assets/images/error-icon.png" mode="aspectFit" class="error-icon"></image>
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="loadOwnerInfo">重试</button>
  </view>
  
  <!-- 机主信息卡片 -->
  <view class="owner-info-card" wx:if="{{!loading && !error && ownerInfo}}">
    <!-- 机主头像和基本信息 -->
    <view class="owner-header">
      <image 
        src="{{ownerInfo.avatarUrl || '/assets/images/user-avatar.png'}}" 
        mode="aspectFill" 
        class="owner-avatar"
      ></image>
      <view class="owner-basic-info">
        <text class="owner-name">{{ownerInfo.realName || '未知姓名'}}</text>
        <text class="owner-id">ID: {{ownerInfo.id}}</text>
      </view>
    </view>
    
    <!-- 详细信息 -->
    <view class="owner-details">
      <view class="detail-section">
        <text class="section-title">联系方式</text>
        <view class="detail-row">
          <text class="detail-label">手机号：</text>
          <text class="detail-value">{{ownerInfo.phoneNumber || '--'}}</text>
          <button 
            class="contact-btn" 
            size="mini" 
            bindtap="makePhoneCall" 
            wx:if="{{ownerInfo.phoneNumber}}"
          >
            拨打
          </button>
        </view>
        <view class="detail-row">
          <text class="detail-label">微信：</text>
          <text class="detail-value">{{ownerInfo.wechat || '--'}}</text>
        </view>
      </view>
      
      <view class="detail-section">
        <text class="section-title">个人信息</text>
        <view class="detail-row">
          <text class="detail-label">身份证号：</text>
          <text class="detail-value">{{ownerInfo.idCardNumber || '--'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">地址：</text>
          <text class="detail-value">{{ownerInfo.address || '--'}}</text>
        </view>
      </view>
      
      <view class="detail-section">
        <text class="section-title">设备信息</text>
        <view class="detail-row">
          <text class="detail-label">设备数量：</text>
          <text class="detail-value">{{ownerInfo.deviceCount || 0}} 台</text>
        </view>
      </view>
    </view>
    
    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button 
        class="primary-btn"
        bindtap="navigateToRentDevice"
      >
        查看可租借设备
      </button>
    </view>
  </view>
</view>