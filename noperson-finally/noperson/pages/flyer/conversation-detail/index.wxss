.conversation-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.message-list {
  flex: 1;
  padding: 10rpx;
  overflow-y: auto;
}

.loading-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

.message-wrapper {
  margin-bottom: 20rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  padding: 10rpx;
}

.other-message {
  justify-content: flex-start;
}

.self-message {
  justify-content: flex-end;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 10rpx;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.message-content {
  max-width: 60%;
}

.self-content {
  text-align: right;
}

.message-bubble {
  padding: 20rpx;
  border-radius: 16rpx;
  word-break: break-word;
  margin-bottom: 5rpx;
}

.other-bubble {
  background-color: #ffffff;
  border-top-left-radius: 4rpx;
}

.self-bubble {
  background-color: #9eea6a;
  border-top-right-radius: 4rpx;
}

.message-text {
  font-size: 28rpx;
  line-height: 40rpx;
  color: #333;
}

.self-bubble .message-text {
  color: #333;
}

.message-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 10rpx;
}

.order-message {
  font-size: 28rpx;
}

.order-id {
  color: #666;
  font-size: 26rpx;
  display: block;
  margin-top: 10rpx;
}

.message-time {
  font-size: 22rpx;
  color: #999;
}

.no-messages {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e0e0e0;
}

.input-wrapper {
  flex: 1;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  padding: 0 20rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
}

.input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  background-color: transparent;
}

.send-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  margin: 0;
  background-color: #9eea6a;
  color: #333;
  font-size: 28rpx;
  border-radius: 30rpx;
}

.send-btn[disabled] {
  background-color: #dcdcdc;
  color: #999;
}