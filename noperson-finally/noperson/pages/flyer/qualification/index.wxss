/* flyer/qualification/index.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #f8fafc, #e2e8f0);
  position: relative;
  overflow-x: hidden;
}

page::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(26, 173, 25, 0.05) 0%, transparent 70%);
  animation: float 20s ease-in-out infinite;
  z-index: -1;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0) rotate(0deg);
  }
  33% {
    transform: translate(20rpx, -20rpx) rotate(120deg);
  }
  66% {
    transform: translate(-20rpx, 20rpx) rotate(240deg);
  }
}

.qualification-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 资质状态区域 */
.status-section {
  padding: 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e0e0e0;
}

/* 可滚动的内容区域 */
.content-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 40rpx;
}

.status-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-title {
  font-size: 32rpx;
  color: #666;
  margin-right: 16rpx;
}

.status-value {
  font-size: 32rpx;
  font-weight: bold;
}

.status-0 {
  color: #ff9500;
}

.status-1 {
  color: #1aad19;
}

.status-2 {
  color: #e64340;
}

/* 审核备注 */
.audit-remark {
  padding: 20rpx;
  background-color: #fff7e6;
  border-radius: 12rpx;
  border: 1rpx solid #ffd699;
}

.remark-label {
  font-size: 28rpx;
  color: #e66700;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.remark-content {
  font-size: 28rpx;
  color: #e66700;
  line-height: 1.5;
}

/* 资质上传表单 */
.qualification-form {
  background-color: #fff;
}

.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.required {
  color: #e64340;
}

/* 表单输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
}

.form-input::placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 上传区域 */
.upload-area {
  width: 100%;
  height: 240rpx;
  border: 2rpx dashed #e0e0e0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.upload-area image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.upload-area text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.upload-tip {
  font-size: 24rpx;
  color: #999;
}

/* 已上传文件 */
.uploaded-file {
  width: 100%;
  height: 100rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  background-color: #fafafa;
}

.file-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.file-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 提交按钮区域 */
.submit-section {
  margin-top: 60rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  background-color: #1aad19;
  color: #fff;
  border-radius: 12rpx;
}

.submit-btn[disabled] {
  background-color: #e0e0e0;
  color: #999;
}

.submit-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 16rpx;
}

/* 审核中提示 */
.auditing-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.auditing-section image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.auditing-text {
  font-size: 36rpx;
  color: #ff9500;
  margin-bottom: 16rpx;
}

.auditing-subtext {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  padding: 0 60rpx;
}

/* 已通过提示 */
.approved-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.approved-section image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border-radius: 50%;
  padding: 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(26, 173, 25, 0.2);
}

.approved-text {
  font-size: 44rpx;
  color: #1aad19;
  margin-bottom: 24rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 4rpx rgba(26, 173, 25, 0.1);
}

.approved-subtext {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 100rpx;
  line-height: 1.6;
}

/* 已通过资质信息 */
.approved-info {
  width: 100%;
  max-width: 650rpx;
  padding: 60rpx;
  background: linear-gradient(135deg, #ffffff, #f8f9fa);
  border-radius: 24rpx;
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  margin: 0 auto;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.approved-info::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #1aad19, #4ade80, #1aad19);
}

.info-item {
  margin-bottom: 48rpx;
  display: flex;
  align-items: flex-start;
  position: relative;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 32rpx;
  color: #666;
  min-width: 200rpx;
  margin-right: 24rpx;
  font-weight: 600;
  opacity: 0.9;
}

.info-value {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  word-break: break-all;
  font-weight: 600;
  background: linear-gradient(135deg, #333, #666);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* 执照图片样式 */
.license-image {
  width: 100%;
  max-height: 500rpx;
  border-radius: 20rpx;
  border: 3rpx solid #e0e0e0;
  background: linear-gradient(135deg, #fafafa, #f0f0f0);
  box-shadow: 
    0 8rpx 24rpx rgba(0, 0, 0, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  transition: all 0.3s ease;
}

.license-image:active {
  transform: scale(0.98);
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

/* 重新上传按钮 */
.reupload-section {
  margin-top: 100rpx;
  padding: 0 40rpx;
}

.reupload-btn {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  font-size: 34rpx;
  background: linear-gradient(135deg, #ff9500, #ff6b00);
  color: #fff;
  border-radius: 20rpx;
  font-weight: 600;
  box-shadow: 
    0 12rpx 30rpx rgba(255, 149, 0, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.reupload-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.reupload-btn:active {
  transform: translateY(4rpx);
  box-shadow: 
    0 6rpx 15rpx rgba(255, 149, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.reupload-btn:active::before {
  left: 100%;
}