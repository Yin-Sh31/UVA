/* flyer/device-return/index.wxss */
.device-return-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e6e6e6;
  border-top: 6rpx solid #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.retry-btn {
  background-color: #07c160;
  color: #fff;
  font-size: 28rpx;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
}

/* 设备列表 */
.device-list {
  padding: 30rpx;
}

.device-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 设备头部 */
.device-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.device-title {
  flex: 1;
}

.device-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 5rpx;
}

.device-type {
  font-size: 26rpx;
  color: #666;
}

.rent-status {
  background-color: #ff6b6b;
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 15rpx;
}

/* 租借信息 */
.rent-info {
  background-color: #f8f8f8;
  padding: 20rpx;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
}

.rent-info-item {
  display: flex;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.info-label {
  color: #666;
  width: 160rpx;
}

.info-value {
  flex: 1;
  color: #333;
}

.info-value.price {
  color: #ff6b6b;
  font-weight: 600;
}

/* 设备详情 */
.device-details {
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.detail-label {
  color: #666;
  width: 180rpx;
}

.detail-value {
  flex: 1;
  color: #333;
  word-break: break-all;
}

/* 归还表单 */
.return-form {
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-input {
  background-color: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.radio-group {
  display: flex;
  flex-direction: column;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  font-size: 28rpx;
  color: #333;
}

.radio-item radio {
  margin-right: 15rpx;
}

.form-textarea {
  background-color: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  height: 150rpx;
  resize: none;
}

/* 操作按钮 */
.device-actions {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.form-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.primary-btn {
  background-color: #07c160;
  color: #fff;
}

.primary-btn:active {
  background-color: #06a855;
}

.cancel-btn {
  background-color: #e6e6e6;
  color: #666;
}

.confirm-btn {
  background-color: #07c160;
  color: #fff;
}

.confirm-btn:active {
  background-color: #06a855;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}