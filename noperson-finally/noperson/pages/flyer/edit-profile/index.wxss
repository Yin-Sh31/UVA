/* 页面容器样式 */
.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 滚动内容区域 */
.content-container {
  flex: 1;
  background-color: #f5f5f5;
  position: relative;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 头像区域 */
.avatar-section {
  padding: 40rpx;
  display: flex;
  justify-content: center;
  background-color: #fff;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.avatar-upload-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
}

.avatar-upload-text {
  font-size: 24rpx;
}

/* 表单区域 */
.form-section {
  margin-top: 20rpx;
  background-color: #fff;
  margin-bottom: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #333;
}

.form-content {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  text-align: right;
}

.form-input {
  text-align: right;
  color: #333;
  font-size: 28rpx;
  padding: 8rpx 0;
  line-height: 40rpx;
}

/* 表单文本区域样式 */
.form-textarea {
  text-align: right;
  height: auto;
  color: #333;
  font-size: 28rpx;
  padding: 8rpx 0;
  line-height: 40rpx;
  min-height: 120rpx;
}

/* 选择器样式 */
.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 40rpx;
}

.form-text {
  color: #999;
  font-size: 28rpx;
  padding: 8rpx 0;
  line-height: 40rpx;
}

.form-input[disabled] {
  color: #999;
}

/* 按钮区域 - 固定在底部 */
.button-section {
  padding: 20rpx 40rpx 40rpx;
  background-color: #f5f5f5;
  display: flex;
  justify-content: space-between;
  z-index: 100;
}

.button-section.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.save-btn {
  background-color: #07c160;
  border-radius: 12rpx;
  font-size: 32rpx;
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  color: #fff;
  margin: 0 10rpx;
}

.cancel-btn {
  background-color: #f8f8f8;
  color: #333;
  border-radius: 12rpx;
  font-size: 32rpx;
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  margin: 0 10rpx;
}

.edit-btn {
  background-color: #07c160;
  border-radius: 12rpx;
  font-size: 32rpx;
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  color: #fff;
  margin: 0;
}

/* 调试信息样式 */
.debug-info {
  font-size: 28rpx;
  color: #333;
  padding: 20rpx;
  margin: 20rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
}

/* 底部间距，确保内容不被固定按钮遮挡 */
.bottom-spacer {
  height: 150rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-content {
  text-align: center;
}

.loading-image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 位置输入区域样式 */
.location-content {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.location-input {
  flex: 1;
  margin-right: 20rpx;
  text-align: right;
}

.get-location-btn {
  min-width: 140rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
}