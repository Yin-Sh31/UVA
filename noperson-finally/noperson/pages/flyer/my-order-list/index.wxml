<view class="container">
  <!-- 自定义导航栏 -->
  <navigation-bar back="true" title="我的接单" bindtap="onBackTap"></navigation-bar>
  
  <!-- 状态筛选 -->
  <view class="status-filter">
    <picker bindchange="switchStatus" value="{{currentStatusIndex}}" range="{{statusList}}" range-key="name">
      <view class="picker">
        <text class="picker-text">当前筛选：{{statusList[currentStatusIndex].name}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>
  
  <!-- 订单列表 -->
  <scroll-view 
    class="order-list"
    scroll-y
    bindscrolltolower="onLoadMore"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <!-- 订单项 -->
    <view class="order-item" wx:for="{{orderList}}" wx:key="id">
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-id">订单编号：{{item.id}}</view>
        <view class="order-status status-{{item.status}}">{{getStatusText(item.status)}}</view>
      </view>
      
      <!-- 订单信息 -->
      <view class="order-info">
        <view class="info-row">
          <view class="info-label">订单类型：</view>
          <view class="info-value">{{item.type === 1 ? '喷洒订单' : '巡检订单'}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">接单时间：</view>
          <view class="info-value">{{item.acceptTime}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">服务面积：</view>
          <view class="info-value">{{item.area || 0}} 亩</view>
        </view>
        <view class="info-row">
          <view class="info-label">服务费用：</view>
          <view class="info-value">¥{{item.paymentAmount || 0}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">服务地点：</view>
          <view class="info-value">{{item.location}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">农户姓名：</view>
          <view class="info-value">{{item.farmerName || '匿名农户'}}</view>
        </view>
      </view>
      
      <!-- 订单操作 -->
      <view class="order-actions">
        <view class="action-btn detail-btn" bindtap="viewOrderDetail" data-id="{{item.id}}">
          查看详情
        </view>
        <view class="action-btn cancel-btn" bindtap="cancelOrder" data-id="{{item.id}}" wx:if="{{item.status === 0}}">
          取消接单
        </view>
      </view>
    </view>
    
    <!-- 加载状态 -->
    <view class="loading-tip" wx:if="{{loading && orderList.length > 0}}">
      <text>加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && orderList.length === 0}}">
      <image class="empty-icon" src="/assets/images/user-info.png"></image>
      <text class="empty-text">暂无接单记录</text>
    </view>
    
    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && orderList.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>