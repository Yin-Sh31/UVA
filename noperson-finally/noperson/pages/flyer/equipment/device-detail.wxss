/* flyer/equipment/device-detail.wxss */
page {
  height: 100vh;
  background-color: #f5f5f5;
}

.device-detail-container {
  padding-top: 88rpx; /* 为导航栏留出空间 */
  padding-bottom: 100rpx;
  height: 100%;
  overflow-y: auto;
  box-sizing: border-box;
}

/* 设备图片样式 */
.device-image-container {
  width: 100%;
  height: 400rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.device-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #eee;
  border-top: 6rpx solid #1AAD19;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-state text {
  margin-top: 20rpx;
  color: #999;
  font-size: 28rpx;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.error-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.error-state text {
  color: #999;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.retry-btn {
  margin-top: 20rpx;
  background: #07c160;
  color: #fff;
}

/* 操作按钮区域样式 */
.action-buttons {
  padding: 30rpx;
  margin-top: 20rpx;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-bottom: 20rpx;
  border: none;
}

.secondary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #f7f7f7;
  color: #666;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: 1rpx solid #ddd;
}

.rented-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 底部操作栏样式 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  box-sizing: border-box;
}

/* 提高按钮样式优先级 */
.bottom-action button {
  margin: 0;
  padding: 0;
  font-size: 32rpx;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.bottom-action .rent-btn {
  width: 100%;
  background: #07c160 !important;
  color: #fff;
  border: none;
}

.bottom-actions-group {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.bottom-actions-group .return-btn {
  flex: 1;
  background: #07c160 !important;
  color: #fff;
  border: none;
}

.bottom-actions-group .cancel-rent-btn {
  flex: 1;
  background: #f7f7f7 !important;
  color: #666 !important;
  border: 1rpx solid #ddd;
}

/* 设备信息 */
.device-info {
  padding: 20rpx;
}

.info-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.device-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.device-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.device-type {
  font-size: 28rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.device-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-item {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.status-item.available .status-dot {
  background-color: #1AAD19;
}

.status-item.unavailable .status-dot {
  background-color: #999;
}

.status-text {
  font-size: 28rpx;
  color: #666;
}

.rent-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B35;
}

/* 详细参数 */
.detail-section,
.maintenance-section,
.owner-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 1;
  padding-left: 20rpx;
}

/* 维护记录 */
.maintenance-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.maintenance-item {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.maintenance-date {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.maintenance-content {
  font-size: 28rpx;
  color: #333;
  line-height: 40rpx;
}

.empty-record {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}

/* 机主信息 */
.owner-info {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.owner-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.owner-details {
  flex: 1;
}

.owner-name {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.owner-phone {
  font-size: 28rpx;
  color: #666;
}

/* 底部操作栏 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
}

/* 底部按钮组样式 */
.bottom-actions-group {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

/* 租借按钮样式 */
.rent-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #1AAD19 !important;
  color: #fff;
  border-radius: 44rpx;
}

.rent-btn::after {
  border: none;
}

/* 归还按钮样式 */
.return-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background-color: #1AAD19 !important;
  color: #fff;
  border-radius: 44rpx;
}

.return-btn::after {
  border: none;
}

/* 取消租借按钮样式 */
.cancel-rent-btn {
  flex: 1;
  height: 88rpx;
  background: #fff !important;
  color: #ee0a24 !important;
  border: 2rpx solid #ee0a24;
  border-radius: 44rpx;
  font-size: 32rpx;
  line-height: 88rpx;
}

/* 统一设置底部按钮样式，确保覆盖默认样式 */
.bottom-action button {
  margin: 0;
  padding: 0;
  width: 100%;
  font-size: 32rpx;
  border-radius: 44rpx;
  height: 88rpx;
}

/* 设备状态提示信息样式 */
.status-info {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 44rpx;
}

/* 适配不同屏幕 */
@media screen and (min-width: 768px) {
  .device-detail-container {
    max-width: 768rpx;
    margin: 0 auto;
  }
}