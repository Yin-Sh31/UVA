/* flyer/equipment/index.wxss */
page {
  height: 100vh;
  background-color: #f5f5f5;
}

.equipment-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 设备网格布局 */
.equipment-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

/* 设备项样式 */
.equipment-item {
  width: calc(50% - 10rpx);
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

/* 设备图片样式 */
.equipment-image-container {
  position: relative;
  width: 100%;
  height: 240rpx;
  background-color: #f5f5f5;
  overflow: hidden;
}

.equipment-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 状态标签 */
.status-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.status-badge.available {
  background-color: #1AAD19;
}

.status-badge.unavailable {
  background-color: #999999;
}

/* 设备列表区域 */
.equipment-scroll {
  flex: 1;
  padding: 10rpx;
  padding-bottom: 20rpx;
  overflow-y: auto;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #eee;
  border-top: 6rpx solid #1AAD19;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-state text {
  margin-top: 20rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  color: #999;
  font-size: 28rpx;
}

/* 设备列表 */
.equipment-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.equipment-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: relative;
  transition: transform 0.2s;
}

.equipment-item:active {
  transform: scale(0.98);
}

.equipment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 设备信息 */
.device-info {
  padding: 20rpx;
}