.message-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.conversation-list {
  height: calc(100vh - 100rpx);
}

.conversation-item {
  display: flex;
  padding: 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
  position: relative;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 30rpx;
  position: relative;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.unread-badge {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  min-width: 40rpx;
  height: 40rpx;
  background-color: #ff4444;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 15rpx;
  border: 3rpx solid #ffffff;
}

.unread-count {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.conversation-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.conversation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-type {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  margin-left: 20rpx;
}

.last-message {
  font-size: 28rpx;
  color: #666;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  margin-bottom: 10rpx;
}

.related-order {
  display: flex;
  align-items: center;
}

.order-tag {
  font-size: 22rpx;
  color: #fff;
  background-color: #1989fa;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  margin-right: 10rpx;
}

.order-id {
  font-size: 22rpx;
  color: #999;
}

.no-conversations {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.no-conversations image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.no-conversation-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.no-conversation-subtext {
  font-size: 24rpx;
  color: #999;
}

.loading-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 24rpx;
}