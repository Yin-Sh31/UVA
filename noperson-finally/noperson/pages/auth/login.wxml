<!-- pages/auth/login.wxml -->
<view class="page">
  <!-- 顶部区域 -->
  <view class="header">
    <view class="logo">
      <image class="logo-image" src="/assets/images/wurenji.jpg" mode="aspectFit"></image>
    </view>
    <text class="title">{{appName || '智慧农业服务平台'}}</text>
    <text class="subtitle">专业的农业无人机服务</text>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 表单容器 -->
    <view class="form-container">
      <!-- 登录方式切换 -->
      <view class="login-type-switch">
        <view class="login-type-item {{loginType === 'password' ? 'active' : ''}}" bindtap="switchLoginType" data-type="password">密码登录</view>
        <view class="login-type-item {{loginType === 'code' ? 'active' : ''}}" bindtap="switchLoginType" data-type="code">验证码登录</view>
      </view>
      
      <!-- 手机号输入 -->
      <view class="form-item">
        <view class="input-wrapper">
          <text class="input-label">手机号</text>
          <input 
            class="input" 
            type="number" 
            placeholder="请输入手机号码" 
            bindinput="onPhoneInput"
            value="{{phone}}"
          />
        </view>
      </view>

      <!-- 密码输入 -->
      <view class="form-item" wx:if="{{loginType === 'password'}}">
        <view class="input-wrapper">
          <text class="input-label">密码</text>
          <input 
            class="input" 
            password="{{!showPassword}}" 
            placeholder="请输入密码" 
            bindinput="onPasswordInput"
            value="{{password}}"
          />
          <text class="toggle-password" bindtap="togglePasswordVisibility">{{showPassword ? '隐藏' : '显示'}}</text>
        </view>
      </view>
      
      <!-- 验证码输入 -->
      <view class="form-item" wx:if="{{loginType === 'code'}}">
        <view class="input-wrapper code-input-wrapper">
          <text class="input-label">验证码</text>
          <input 
            class="input code-input" 
            type="number" 
            placeholder="请输入验证码" 
            bindinput="onCodeInput"
            value="{{code}}"
          />
          <text class="send-code-btn" bindtap="sendVerificationCode" disabled="{{countdown > 0}}">{{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}</text>
        </view>
      </view>

      <!-- 角色选择 -->
      <view class="role-selector">
        <view class="role-item {{selectedRole === 'farmer' ? 'active' : ''}}" bindtap="onRoleSelect" data-role="farmer">
          <image class="role-icon" src="/assets/images/nonghu.jpg" mode="aspectFit"></image>
          <text class="role-text">农户</text>
        </view>
        <view class="role-item {{selectedRole === 'flyer' ? 'active' : ''}}" bindtap="onRoleSelect" data-role="flyer">
          <image class="role-icon" src="/assets/images/feishou.jpg" mode="aspectFit"></image>
          <text class="role-text">飞手</text>
        </view>
      </view>

      <!-- 登录按钮 -->
      <view class="login-btn" bindtap="onLogin">登录</view>

      <!-- 忘记密码 -->
      <view class="forgot-password" bindtap="onForgotPassword">忘记密码？</view>

      <!-- 注册链接 -->
      <view class="register-link" bindtap="goToRegister">
        还没有账号？立即注册
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">智慧农业服务平台 © 2024</text>
  </view>
</view>