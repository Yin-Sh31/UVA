/* register.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #1aad19 0%, #f5f5f5 25%);
}

.register-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.form-container {
  flex: 1;
  padding: 40rpx;
  background-color: transparent;
  overflow-y: auto;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  margin-top: 40rpx;
}

.input-group {
  margin-bottom: 36rpx;
}

.input-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
}

.input-label::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #1aad19, #16a085);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #333;
  background: linear-gradient(to right, #fafafa, #fff);
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #1aad19;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(26, 173, 25, 0.1);
}

.password-input {
  position: relative;
}

.eye-icon {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(26, 173, 25, 0.1);
  border-radius: 8rpx;
}

.eye-icon image {
  width: 32rpx;
  height: 32rpx;
}

.password-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
  padding-left: 8rpx;
  line-height: 36rpx;
}

.picker {
  width: 100%;
  height: 96rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(to right, #fafafa, #fff);
  transition: all 0.3s ease;
}

.picker:focus-within {
  border-color: #1aad19;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(26, 173, 25, 0.1);
}

.picker-text {
  font-size: 30rpx;
  color: #333;
}

.picker-arrow {
  width: 20rpx;
  height: 20rpx;
}

.picker-arrow image {
  width: 20rpx;
  height: 20rpx;
}

.agreement-container {
  display: flex;
  align-items: flex-start;
  margin: 40rpx 0;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(26, 173, 25, 0.03), rgba(22, 160, 133, 0.03));
  border-radius: 16rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.checkbox image {
  width: 44rpx;
  height: 44rpx;
}

.agreement-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 48rpx;
}

.agreement-link {
  color: #1aad19;
  text-decoration: underline;
  font-weight: 500;
}

.register-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #e0e0e0, #d0d0d0);
  color: #999;
  font-size: 34rpx;
  font-weight: bold;
  line-height: 100rpx;
  margin-top: 48rpx;
  box-shadow: none;
  transition: all 0.3s ease;
  letter-spacing: 2rpx;
}

.register-btn-active {
  background: linear-gradient(135deg, #1aad19, #16a085);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(26, 173, 25, 0.35);
}

.register-btn-active:active {
  transform: scale(0.98);
  opacity: 0.9;
  box-shadow: 0 4rpx 12rpx rgba(26, 173, 25, 0.25);
}

.login-link {
  margin-top: 40rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666;
  padding: 24rpx 0;
  background: linear-gradient(to right, rgba(26, 173, 25, 0.05), rgba(22, 160, 133, 0.05));
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.login-link:active {
  background: linear-gradient(to right, rgba(26, 173, 25, 0.1), rgba(22, 160, 133, 0.1));
}