<!-- register.wxml -->
<view class="register-container">
  <navigation-bar title="用户注册" back="true" color="black" background="#FFF"></navigation-bar>
  
  <view class="form-container">
    <!-- 用户名输入框 -->
    <view class="input-group">
      <view class="input-label">用户名</view>
      <input 
        class="input" 
        type="text" 
        placeholder="请输入用户名"
        value="{{username}}"
        bindinput="onUsernameInput"
      />
    </view>
    
    <!-- 密码输入框 -->
    <view class="input-group">
      <view class="input-label">密码</view>
      <view class="password-input">
        <input 
          class="input" 
          type="{{showPassword ? 'text' : 'password'}}"
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
        <view class="eye-icon" bindtap="togglePasswordVisibility">
          <image 
            src="{{showPassword ? '/assets/images/eye-open.png' : '/assets/images/eye-close.png'}}"
            mode="aspectFit"
          ></image>
        </view>
      </view>
      <view class="password-tip">{{passwordRule}}</view>
    </view>
    
    <!-- 确认密码输入框 -->
    <view class="input-group">
      <view class="input-label">确认密码</view>
      <view class="password-input">
        <input 
          class="input" 
          type="{{showConfirmPassword ? 'text' : 'password'}}"
          placeholder="请再次输入密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
        />
        <view class="eye-icon" bindtap="toggleConfirmPasswordVisibility">
          <image 
            src="{{showConfirmPassword ? '/assets/images/eye-open.png' : '/assets/images/eye-close.png'}}"
            mode="aspectFit"
          ></image>
        </view>
      </view>
    </view>
    
    <!-- 手机号输入框 -->
    <view class="input-group">
      <view class="input-label">手机号</view>
      <input 
        class="input" 
        type="number" 
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>
    
    <!-- 真实姓名输入框 -->
    <view class="input-group">
      <view class="input-label">真实姓名</view>
      <input 
        class="input" 
        type="text" 
        placeholder="请输入真实姓名"
        value="{{realName}}"
        bindinput="onRealNameInput"
      />
    </view>
    
    <!-- 角色选择 -->
    <view class="input-group">
      <view class="input-label">角色选择</view>
      <picker bindchange="onRoleChange" value="{{roleIndex}}" range="{{roleOptions}}">
        <view class="picker">
          <text class="picker-text">{{role === 'farmer' ? '农户' : role === 'flyer' ? '飞手' : '机主'}}</text>
          <view class="picker-arrow">
            <image src="/assets/images/arrow-down.png" mode="aspectFit"></image>
          </view>
        </view>
      </picker>
    </view>
    
    <!-- 用户协议 -->
    <view class="agreement-container">
      <view class="checkbox" bindtap="toggleAgreement">
        <image 
          src="{{agreementChecked ? '/assets/images/checkbox-checked.png' : '/assets/images/checkbox-unchecked.png'}}"
          mode="aspectFit"
        ></image>
      </view>
      <view class="agreement-text">
        我已阅读并同意<a href="" class="agreement-link">《用户协议》</a>和<a href="" class="agreement-link">《隐私政策》</a>
      </view>
    </view>
    
    <!-- 注册按钮 -->
    <button 
      class="register-btn {{username && password && confirmPassword && phone && realName && agreementChecked ? 'register-btn-active' : ''}}"
      disabled="{{!username || !password || !confirmPassword || !phone || !realName || !agreementChecked || loading}}"
      bindtap="register"
      loading="{{loading}}"
    >
      注册
    </button>
    
    <!-- 返回登录 -->
    <view class="login-link" bindtap="goToLogin">
      <text>已有账号？返回登录</text>
    </view>
  </view>
</view>