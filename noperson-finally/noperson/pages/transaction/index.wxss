/* pages/transaction/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 类型选择器样式 */
.type-selector {
  display: flex;
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 0 20rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  position: relative;
}

.type-item text {
  font-size: 28rpx;
  color: #666;
}

.type-item.active text {
  color: #FF4D4F;
  font-weight: 500;
}

.type-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 4rpx;
  background-color: #FF4D4F;
  border-radius: 2rpx;
}

.transaction-list {
  flex: 1;
  height: 100vh;
  padding: 20rpx;
}

.transaction-item {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.transaction-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.transaction-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.transaction-amount {
  font-size: 36rpx;
  font-weight: bold;
}

.transaction-amount.income {
  color: #FF4D4F;
}

.transaction-amount.expense {
  color: #52C41A;
}

.transaction-time {
  font-size: 26rpx;
  color: #999;
}

.transaction-divider {
  margin-top: 20rpx;
  height: 1rpx;
  background-color: #f0f0f0;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-more, .no-more {
  text-align: center;
  padding: 20rpx 0;
  color: #999;
  font-size: 26rpx;
}