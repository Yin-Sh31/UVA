/* index.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.role-select-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
  background-color: #fff;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.sub-text {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
  display: block;
}

.role-list {
  flex: 1;
  padding: 40rpx;
  background-color: #fff;
  margin-top: 20rpx;
  overflow-y: auto;
}

.role-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  position: relative;
}

.role-item-selected {
  border-color: #1aad19;
  background-color: rgba(26, 173, 25, 0.05);
}

.role-icon {
  width: 120rpx;
  height: 120rpx;
  margin-right: 32rpx;
}

.role-icon image {
  width: 100%;
  height: 100%;
}

.role-info {
  flex: 1;
}

.role-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.role-description {
  font-size: 26rpx;
  color: #666;
  line-height: 36rpx;
}

.role-check {
  width: 48rpx;
  height: 48rpx;
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}

.role-check image {
  width: 100%;
  height: 100%;
}

.footer {
  padding: 40rpx;
  background-color: #fff;
  margin-top: 20rpx;
}

.enter-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background-color: #e0e0e0;
  color: #999;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 96rpx;
  margin-bottom: 24rpx;
}

.enter-btn-active {
  background-color: #1aad19;
  color: #fff;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background-color: #fff;
  color: #e64340;
  border: 2rpx solid #e64340;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 96rpx;
}