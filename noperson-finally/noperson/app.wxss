/**app.wxss**/
/* 全局样式变量 */
:root {
  /* 主色调 - 绿色（农业属性） */
  --primary-color: #1AAD19;
  --primary-light: #E6F7EF;
  --primary-dark: #0A8B0A;
  
  /* 辅助色 */
  --secondary-orange: #FF9500;
  --secondary-blue: #007AFF;
  --secondary-red: #FF3B30;
  --secondary-gray: #F5F5F5;
  
  /* 文字颜色 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  
  /* 背景颜色 */
  --bg-primary: #FFFFFF;
  --bg-secondary: #F5F5F5;
  --bg-card: #FFFFFF;
  
  /* 边框颜色 */
  --border-color: #EEEEEE;
  
  /* 间距 */
  --spacing-xs: 10rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 30rpx;
  --spacing-lg: 40rpx;
  --spacing-xl: 50rpx;
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  
  /* 字体大小 */
  --font-size-xs: 24rpx;
  --font-size-sm: 28rpx;
  --font-size-base: 32rpx;
  --font-size-lg: 36rpx;
  --font-size-xl: 40rpx;
  
  /* 字体粗细 */
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-bold: 600;
}

/* 基础样式重置 */
page, view, text, button, input, textarea, image, swiper, swiper-item, navigator {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

page {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-normal);
  line-height: 1.5;
  -webkit-text-size-adjust: 100%;
}

/* 通用容器样式 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0;
  box-sizing: border-box;
}

/* 通用按钮样式 */
button {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background-color: transparent;
  border: none;
  outline: none;
}

/* 通用文本样式 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

/* 通用卡片样式 */
.card {
  background-color: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

/* 通用分隔线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: var(--spacing-md) 0;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) 0;
  color: var(--text-tertiary);
}

/* 加载状态样式 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) 0;
}
