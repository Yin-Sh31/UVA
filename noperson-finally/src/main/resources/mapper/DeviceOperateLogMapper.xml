<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cty.nopersonfinally.mapper.DeviceOperateLogMapper">

    <!-- 分页查询设备操作日志 -->
    <select id="selectDeviceLogs" resultType="com.cty.nopersonfinally.pojo.entity.DeviceOperateLog">
        SELECT * FROM t_device_operate_log 
        WHERE device_id = #{deviceId}
        <if test="startTime != null and startTime != ''">
            AND operate_time &gt;= #{startTime}
        </if>
        <if test="endTime != null and endTime != ''">
            AND operate_time &lt;= #{endTime}
        </if>
        <if test="operateType != null">
            AND operate_type = #{operateType}
        </if>
        ORDER BY operate_time DESC
    </select>

</mapper>